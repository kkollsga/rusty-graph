# Skip specific directories
/pytest/
/venv/
/.venv/
/.venv*/
/.claude/
/.pytest_cache/
/data/
/dev-documentation/
/bench/
/inbox/

# Ignore Rust build artifacts (keep wheels for distribution)
/target/
!/target/wheels/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Compiled extension modules (built by maturin develop)
*.so
*.pyd

# Bundled native binary copied into the wheel build dir at CI time.
# Platform-specific outputs (per-arch, per-Python-version) — never
# checked in. Maturin's pyproject.toml `[tool.maturin] include = [...]`
# overrides .gitignore at packaging time.
/kglite/_bin/

# IDE and editor settings
.vscode/

# Performance baselines (dev artifacts)
/baselines/
/.benchmarks/

# Hypothesis database (property-based testing cache)
/.hypothesis/

# Coverage data
.coverage
coverage.xml

# Generated graph files
*.kgl

# Sphinx docs build output
docs/_build/
docs/autoapi/

# macOS system files
.DS_Store
/projects/
